# DO NOT PUSH CHANGES OF THIS FILE TO opentelemetry/opentelemetry-demo
# PLACE YOUR .env ENVIRONMENT VARIABLES OVERRIDES IN THIS FILE

# Load-generator stability: disable Playwright/Chromium browser users.
# The WebsiteBrowserUser class leaks Chromium memory over time, OOM-killing
# the container after ~2 days (reported: https://github.com/open-telemetry/opentelemetry-demo/issues/2678).
# HTTP-only Locust users are far lighter and sufficient for long-running demos.
LOCUST_BROWSER_TRAFFIC_ENABLED=false

# 500 users is the default but very aggressive. Lower this to reduce memory
# pressure on the load-generator and downstream services for long-running demos.
LOCUST_USERS=50


# To use a real OpenAI API-compatible LLM,
# set the appropriate values for the target LLM
# Required permissions:
# [Models and Model capabilities]

#LLM_BASE_URL=https://api.openai.com/v1
#LLM_MODEL=gpt-4o-mini
#OPENAI_API_KEY=<replace with API key>
